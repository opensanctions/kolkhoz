# Pravda is an in-process async library. Kolkhoz owns and runs the
# infrastructure it connects to: a remote headed Chrome (Playwright
# run-server), a Postgres database shared by Pravda and Kolkhoz, and an fsspec
# artifact store. Both applications use this asyncpg URL through SQLAlchemy.
# Bring them up with: docker compose up -d
PRAVDA_DATABASE_URL=postgresql+asyncpg://pravda:pravda@localhost:5432/pravda
PRAVDA_BROWSER_WS_URL=ws://localhost:3000
PRAVDA_STORAGE_BASE_PATH=./storage

# fsspec paths for the input directory (CSVs) and export output
# (local path or gs://bucket/...)
INPUT_BASE_PATH=./input
OUTPUT_BASE_PATH=./output
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
IMAGE_TILE_SIZE=2048
IMAGE_TILE_OVERLAP=0.05
